[Unit]
Description=Cloudflared quick tunnel for OCR_HVKS API
After=network-online.target ocr-hvks-api.service
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/AI_project/OCR_HVKS
EnvironmentFile=-/home/%i/AI_project/OCR_HVKS/.env
ExecStart=/usr/bin/env bash /home/%i/AI_project/OCR_HVKS/deploy/start_cloudflared.sh
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
