[Unit]
Description=vLLM server (Qwen3.6) for OCR_HVKS
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/AI_project/OCR_HVKS
EnvironmentFile=-/home/%i/AI_project/OCR_HVKS/.env
ExecStart=/usr/bin/env bash /home/%i/AI_project/OCR_HVKS/deploy/start_vllm.sh
Restart=on-failure
RestartSec=10
TimeoutStartSec=600
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
