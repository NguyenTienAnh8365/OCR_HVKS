# ============================================================
# OCR_HVKS — config mẫu. Copy thành .env rồi chỉnh.
# ============================================================

# ---------- LLM backend (vLLM, OpenAI-compatible) ----------
# URL nội bộ tới vLLM. Trên cùng máy với FastAPI dùng localhost:
LLM_BASE_URL=http://localhost:8008
MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# ---------- vLLM launch (chỉ dùng bởi deploy/start_vllm.sh) ----------
VLLM_HOST=0.0.0.0
VLLM_PORT=8008
TP_SIZE=2                       # 2 GPU RTX PRO 6000 Blackwell → tensor-parallel 2
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=24576
MAX_NUM_SEQS=256
MAX_NUM_BATCHED_TOKENS=65536
KV_CACHE_DTYPE=fp8_e5m2
DTYPE=bfloat16
CUDA_VISIBLE_DEVICES=0,1
HF_HOME=/home/abc/model/qwen3.6

# ---------- FastAPI (combined) ----------
API_HOST=0.0.0.0
API_PORT=8900
API_WORKERS=1
API_LOG_LEVEL=info

# ---------- OCR ----------
MAX_WORKERS=128
DPI=250
# Linux server: để trống (poppler-utils đã trong PATH).
# Windows dev: trỏ tới thư mục bin Poppler nếu chưa trong PATH.
POPPLER_PATH=

# ---------- LaTeX ----------
LATEX_PAGES_PER_CHUNK=5
LATEX_CHUNK_WORKERS=5

# ---------- Debug ----------
DEBUG_DIR=./debug/latex
