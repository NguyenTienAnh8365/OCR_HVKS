# ============================================================
# OCR_HVKS — config mẫu. Copy thành .env rồi chỉnh.
# ============================================================

# ---------- LLM backend (vLLM, OpenAI-compatible) ----------
# URL nội bộ tới vLLM. Trên cùng máy với FastAPI dùng localhost:
LLM_BASE_URL=http://localhost:8008
MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# ---------- vLLM launch (chỉ dùng bởi deploy/start_vllm.sh) ----------
VLLM_HOST=0.0.0.0
VLLM_PORT=8008
TP_SIZE=2                       # 2 GPU RTX PRO 6000 Blackwell → tensor-parallel 2
GPU_MEMORY_UTILIZATION=0.80
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=512
MAX_NUM_BATCHED_TOKENS=65536
KV_CACHE_DTYPE=fp8_e5m2
DTYPE=bfloat16
CUDA_VISIBLE_DEVICES=0,1
HF_HOME=/home/abc/model/qwen3.6

# ---------- FastAPI (combined) ----------
API_HOST=0.0.0.0
API_PORT=8900
API_WORKERS=1
API_LOG_LEVEL=info
# Chốt chặn runaway (vượt → 503) và thời gian chờ request xong khi restart.
API_LIMIT_CONCURRENCY=1024
API_TIMEOUT_GRACEFUL=30

# ---------- OCR ----------
# Trần số trang OCR gọi vLLM đồng thời trên toàn app (mọi request cộng lại).
# Đặt xấp xỉ MAX_NUM_SEQS ở trên.
LLM_CONCURRENCY=512
DPI=300
# Linux server: để trống (poppler-utils đã trong PATH).
# Windows dev: trỏ tới thư mục bin Poppler nếu chưa trong PATH.
POPPLER_PATH=

# Giới hạn input + deadline job (chống file lỗi/khổng lồ làm sập server).
MAX_UPLOAD_MB=200
MAX_PDF_PAGES=1000
OCR_REQUEST_TIMEOUT_S=1800

# ---------- LaTeX ----------
LATEX_PAGES_PER_CHUNK=4
LATEX_CHUNK_WORKERS=4

# ---------- Debug ----------
DEBUG_DIR=./debug/latex
