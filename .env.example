# ============================================================
# OCR_HVKS — config mẫu. Copy thành .env rồi chỉnh.
# ============================================================

# ---------- LLM backend (SGLang, OpenAI-compatible) ----------
# URL nội bộ tới SGLang server. Trên cùng máy với FastAPI:
LLM_BASE_URL=http://100.75.29.73:8008
MODEL_NAME=Qwen/Qwen3.6-27B

# ---------- SGLang launch (chỉ dùng bởi deploy/start_sglang.sh) ----------
SGLANG_PORT=8008
SGLANG_HOST=0.0.0.0
TP_SIZE=2                       # 2 GPU RTX PRO 6000 Blackwell → tensor-parallel 2
MEM_FRACTION_STATIC=0.88
CONTEXT_LENGTH=100000
MAX_RUNNING_REQUESTS=64
KV_CACHE_DTYPE=fp8_e5m2
CHAT_TEMPLATE=qwen2-vl
CUDA_VISIBLE_DEVICES=0,1

# ---------- FastAPI (combined) ----------
API_HOST=0.0.0.0
API_PORT=8900
API_WORKERS=1
API_LOG_LEVEL=info

# ---------- OCR ----------
MAX_WORKERS=32
DPI=300
# Linux server: để trống (poppler-utils đã trong PATH).
# Windows dev: trỏ tới thư mục bin Poppler nếu chưa trong PATH.
POPPLER_PATH=

# ---------- LaTeX ----------
LATEX_PAGES_PER_CHUNK=4
LATEX_CHUNK_WORKERS=4

# ---------- Debug ----------
DEBUG_DIR=./debug/latex
