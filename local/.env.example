# URL tunnel của vLLM trên Colab (không kèm /v1/...)
VLLM_BASE_URL=https://vks-ocr-hvks.loca.lt
MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# Port cho 2 FastAPI local
OCR_PORT=8900
LATEX_PORT=8901

# OCR
MAX_WORKERS=24
DPI=300

# Thư mục debug cho LaTeX/PDF
DEBUG_DIR=./debug_latex

# Windows: đường dẫn tới thư mục bin của Poppler (ví dụ: C:\poppler-24.08.0\Library\bin)
# Để trống nếu đã có poppler trong PATH.
POPPLER_PATH=
